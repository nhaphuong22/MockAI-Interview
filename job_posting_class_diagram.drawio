<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    
    <!-- JobController Class -->
    <mxCell id="c_controller" value="&lt;b&gt;JobController&lt;/b&gt;&lt;hr/&gt;- jobService: JobService&lt;hr/&gt;+ createJob(req, res): Promise&amp;lt;void&amp;gt;&lt;br&gt;+ getJobs(req, res): Promise&amp;lt;void&amp;gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#e8f4f8;strokeColor=#0ea5e9;fontColor=#0369a1;" vertex="1" parent="1">
      <mxGeometry x="40" y="40" width="220" height="120" as="geometry"/>
    </mxCell>
    
    <!-- JobService Class -->
    <mxCell id="c_service" value="&lt;b&gt;JobService&lt;/b&gt;&lt;hr/&gt;- jobRepository: JobRepository&lt;br&gt;- aiService: AIService&lt;hr/&gt;+ createJob(data, hrId): Promise&amp;lt;Job&amp;gt;&lt;br&gt;+ validateJobData(data): void&lt;br&gt;+ getJobById(id): Promise&amp;lt;Job&amp;gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#e8f4f8;strokeColor=#0ea5e9;fontColor=#0369a1;" vertex="1" parent="1">
      <mxGeometry x="340" y="40" width="240" height="140" as="geometry"/>
    </mxCell>
    
    <!-- AIService Class -->
    <mxCell id="c_ai" value="&lt;b&gt;AIService&lt;/b&gt;&lt;hr/&gt;- aiClient: OpenAI/Anthropic&lt;hr/&gt;+ generateJobContext(jobId, jd): Promise&amp;lt;void&amp;gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#fff9e6;strokeColor=#f59e0b;fontColor=#92400e;" vertex="1" parent="1">
      <mxGeometry x="660" y="40" width="240" height="120" as="geometry"/>
    </mxCell>
    
    <!-- Job Model Class -->
    <mxCell id="c_model_job" value="&lt;b&gt;Job (Entity)&lt;/b&gt;&lt;hr/&gt;+ id: string&lt;br&gt;+ title: string&lt;br&gt;+ description: string&lt;br&gt;+ companyId: string&lt;br&gt;+ hrId: string&lt;br&gt;+ categoryId: string&lt;br&gt;+ locationId: string&lt;br&gt;+ jobTypeId: string&lt;br&gt;+ createdAt: Date" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#e8f5e9;strokeColor=#10b981;fontColor=#065f46;" vertex="1" parent="1">
      <mxGeometry x="40" y="260" width="220" height="180" as="geometry"/>
    </mxCell>
    
    <!-- JobRequirement Model Class -->
    <mxCell id="c_model_req" value="&lt;b&gt;JobRequirement (Entity)&lt;/b&gt;&lt;hr/&gt;+ id: string&lt;br&gt;+ jobId: string&lt;br&gt;+ requirement: string&lt;br&gt;+ isMandatory: boolean" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#e8f5e9;strokeColor=#10b981;fontColor=#065f46;" vertex="1" parent="1">
      <mxGeometry x="340" y="260" width="240" height="120" as="geometry"/>
    </mxCell>
    
    <!-- JobSkill Model Class -->
    <mxCell id="c_model_skill" value="&lt;b&gt;JobSkill (Entity)&lt;/b&gt;&lt;hr/&gt;+ jobId: string&lt;br&gt;+ skillId: string" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#e8f5e9;strokeColor=#10b981;fontColor=#065f46;" vertex="1" parent="1">
      <mxGeometry x="660" y="260" width="240" height="100" as="geometry"/>
    </mxCell>

    <!-- Associations & Dependencies -->
    <!-- Controller -> Service -->
    <mxCell id="e1" edge="1" source="c_controller" target="c_service" style="endArrow=classic;html=1;strokeColor=#0ea5e9;" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <!-- Service -> AIService -->
    <mxCell id="e2" edge="1" source="c_service" target="c_ai" style="endArrow=classic;html=1;strokeColor=#0ea5e9;" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <!-- Service -> Job (Entity) -->
    <mxCell id="e3" edge="1" source="c_service" target="c_model_job" style="endArrow=classic;dashed=1;html=1;strokeColor=#10b981;" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <!-- Job (Entity) 1 <-> * JobRequirement (Entity) -->
    <mxCell id="e4" value="1              *" edge="1" source="c_model_job" target="c_model_req" style="endArrow=diamond;endFill=0;html=1;strokeColor=#10b981;fontColor=#065f46;" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <!-- Job (Entity) 1 <-> * JobSkill (Entity) -->
    <mxCell id="e5" value="1              *" edge="1" source="c_model_job" target="c_model_skill" style="endArrow=diamond;endFill=0;html=1;strokeColor=#10b981;fontColor=#065f46;" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
